# Savastano Advisory production environment contract
# Copy to a private .env.production file outside git and replace every placeholder.
# This file documents the target production contract for T5 cycle 5.

# Runtime mode. Production deploys must run with production optimizations enabled.
NODE_ENV=production

# TCP port exposed by the app process behind the reverse proxy.
PORT=3000

# Canonical public origin used for redirects, portal links, and operational checks.
# Use the real HTTPS domain that will front the Next.js app.
APP_BASE_URL=https://savastanoadvisory.com.br

# Shared operator secret required by apps/web/proxy.ts for /cockpit and /api/cockpit access.
# Replace with a long random value, do not commit the real secret.
COCKPIT_SECRET=replace-with-a-long-random-secret

# Database provider contract for production.
# Current local runtime remains SQLite-first. PostgreSQL migration steps are documented in docs/postgres-migration.md.
DATABASE_PROVIDER=postgresql

# PostgreSQL connection string for the production database.
# Format: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=postgresql://savastano_advisory:replace-me@db.example.com:5432/savastano_advisory?sslmode=require

# Default archive path used by backup/restore operations.
# Keep this on durable storage outside the repo checkout.
BACKUP_ARCHIVE=/var/backups/savastano-advisory/savastano-advisory-latest.tar.gz

# Optional legacy toggle kept for compatibility with the earlier environment contract.
# Leave disabled in production unless a specific operational drill requires the internal control surface.
CONTROL_ROOM_ENABLED=0
