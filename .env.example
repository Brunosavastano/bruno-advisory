NODE_ENV=development
PORT=3000
APP_BASE_URL=http://127.0.0.1:3000
CONTROL_ROOM_ENABLED=true
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./data/dev/savastano-advisory-dev.sqlite3
BACKUP_ARCHIVE=infra/backups/savastano-advisory-t0-local-latest.tar.gz

# ----------------------------------------------------------------------
# AI gateway (AI-1 Cycle 2). All AI features are off by default — flip
# AI_ENABLED to 'true' on the server only after ANTHROPIC_API_KEY is provisioned.
# ----------------------------------------------------------------------
# Master kill switch. AI routes return 503 until this is 'true'.
AI_ENABLED=false
# Active provider. Only 'anthropic' is wired up in Cycle 2; the gateway is provider-agnostic.
AI_PROVIDER=anthropic
# Pinned model id. Do NOT use 'latest'. Promotion goes through /api/cockpit/ai/model-versions PATCH
# after a golden-set comparison.
AI_MODEL=claude-sonnet-4-6
# Anthropic API key. Provisioned by the operator at console.anthropic.com.
# Empty in this example; real key lives only in the server's private .env.
ANTHROPIC_API_KEY=
# Mock mode for local dev / verifier. Set to '1' to bypass the real provider.
AI_USE_MOCK=0
# Default monthly cap (in US cents) seeded into ai_budget_caps when an admin sets one via API.
# This is documentation only — the actual cap row lives in SQLite. Default cap value: US$50/month.
AI_DEFAULT_MONTHLY_BUDGET_CENTS=5000
# Dev-only harness gate. Set to '1' only when running infra/scripts/verifier scripts that exercise
# the /api/dev/* routes. NEVER set to '1' in production.
AI_DEV_HARNESS_ENABLED=0
# Retry policy for transient provider failures (rate_limited / 5xx). 1 = no retry; 3 = default per
# AI-1 Cycle 3 (covers most rate limit blips with backoff 1s/2s).
AI_RETRY_MAX_ATTEMPTS=3
